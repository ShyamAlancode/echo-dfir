# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtualenv
.venv/
venv/
env/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.mypy_cache/
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Forensic artifacts — never commit case data
samples/*.raw
samples/*.mem
samples/*.dd
samples/*.E01
samples/*.vmem
samples/*.dmp

# Per-run state (committed run outputs are in audit/iterations.jsonl handled separately)
audit/*.jsonl
findings/*.json
findings/*.md
reflection_memory/*.json
!audit/.gitkeep
!findings/.gitkeep
!reflection_memory/.gitkeep

# Secrets
.env
.env.local
*.pem
*.key

# Volatility 3 cache
*.cache
*.vol3
